generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BoardStatus {
  unclaimed
  active
  stolen
  transferred
}

enum ClaimType {
  claim
  transfer
}

enum MessageStatus {
  new
  forwarded
  read
  archived
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String?
  role         Role         @default(USER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ownedBoards  Board[]      @relation("BoardOwner")
  claims       BoardClaim[]

  @@index([email])
}

model BoardModel {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  variants    BoardVariant[]

  @@index([code])
}

model BoardVariant {
  id           String      @id @default(cuid())
  boardModelId String
  sizeCm       Int
  widthCm      Float?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  boardModel   BoardModel  @relation(fields: [boardModelId], references: [id], onDelete: Restrict)
  boards       Board[]

  @@unique([boardModelId, sizeCm])
  @@index([boardModelId])
}

model Board {
  id             String         @id @default(cuid())
  publicId       String         @unique
  serialNumber   String         @unique
  boardVariantId String
  ownerUserId    String?
  status         BoardStatus    @default(unclaimed)
  publicUrl      String
  hash           String?
  isPublic       Boolean        @default(true)
  productionYear Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  boardVariant   BoardVariant   @relation(fields: [boardVariantId], references: [id], onDelete: Restrict)
  ownerUser      User?          @relation("BoardOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  claims         BoardClaim[]
  scans          ScanLog[]
  contactMessages ContactMessage[]

  @@index([publicId])
  @@index([serialNumber])
  @@index([status])
  @@index([ownerUserId])
}

model BoardClaim {
  id         String      @id @default(cuid())
  boardId    String
  userId     String
  type       ClaimType
  claimedAt  DateTime    @default(now())
  releasedAt DateTime?

  board      Board       @relation(fields: [boardId], references: [id], onDelete: Restrict)
  user       User        @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([boardId, claimedAt])
  @@index([userId])
}

model ScanLog {
  id        String    @id @default(cuid())
  boardId   String
  scannedAt DateTime  @default(now())
  userAgent String?
  ip        String?
  source    String?

  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, scannedAt])
}

model ContactMessage {
  id           String        @id @default(cuid())
  boardId       String
  senderName    String
  senderEmail   String?
  senderPhone   String?
  message       String
  locationText  String?
  createdAt     DateTime      @default(now())
  forwardedAt   DateTime?
  readAt        DateTime?
  status        MessageStatus @default(new)

  board         Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
  @@index([status])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  body      String
  updatedAt DateTime @updatedAt

  @@index([key])
}
